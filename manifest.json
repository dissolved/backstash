{
  "manifest_version": 3,
  "name": "Backstash",
  "version": "0.2.0",
  "description": "Minimal proof of concept: close current tab and reopen it later.",
  "permissions": ["tabs", "storage", "alarms", "notifications", "cookies"],
  "background": {
    "scripts": [
      "constants.js",
      "storage.js",
      "restore-logic.js",
      "stash-presets.js",
      "background.js"
    ]
  },
  "action": {
    "default_title": "Stash tab"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "backstash@codedissolved.com",
      "strict_min_version": "109.0"
    }
  },
  "commands": {
    "duration-1": {
      "suggested_key": {
        "default": "Ctrl+Alt+1",
        "mac": "MacCtrl+Alt+1"
      },
      "description": "Stash duration preset 1"
    },
    "duration-2": {
      "suggested_key": {
        "default": "Ctrl+Alt+2",
        "mac": "MacCtrl+Alt+2"
      },
      "description": "Stash duration preset 2"
    },
    "duration-3": {
      "suggested_key": {
        "default": "Ctrl+Alt+3",
        "mac": "MacCtrl+Alt+3"
      },
      "description": "Stash duration preset 3"
    },
    "repeat-last-stash": {
      "suggested_key": {
        "default": "Ctrl+Alt+R",
        "mac": "MacCtrl+Alt+R"
      },
      "description": "Repeat last stash"
    }
  }
}
