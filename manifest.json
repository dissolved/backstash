{
  "manifest_version": 3,
  "name": "Backstash",
  "version": "0.2.0",
  "description": "Minimal proof of concept: close current tab and reopen it later.",
  "permissions": ["tabs", "storage", "alarms", "notifications", "cookies"],
  "background": {
    "scripts": ["constants.js", "storage.js", "restore-logic.js", "stash-presets.js", "background.js"]
  },
  "action": {
    "default_title": "Stash tab"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "backstash@codedissolved.com",
      "strict_min_version": "109.0"
    }
  },
  "commands": {
    "duration-1": {
      "suggested_key": {
        "default": "Ctrl+Shift+1",
        "mac": "Ctrl+Shift+1"
      },
      "description": "Stash tab for 1 minute"
    },
    "duration-2": {
      "suggested_key": {
        "default": "Ctrl+Shift+2",
        "mac": "Ctrl+Shift+2"
      },
      "description": "Stash tab for 1 hour"
    },
    "duration-3": {
      "suggested_key": {
        "default": "Ctrl+Shift+3",
        "mac": "Ctrl+Shift+3"
      },
      "description": "Stash tab for 1 day"
    }
  }
}
